# General Application Environment (development / production)
ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopify_listing
REDIS_URL=redis://localhost:6379/0

# Access Control Whitelist (Comma separated sender phone numbers)
ADMIN_PHONE_WHITELIST=+12345678901,+19876543210

# Meta Webhook Verification Tokens (Set these during webhook registration)
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token
WHATSAPP_APP_SECRET=your_meta_app_secret

# Meta Graph Cloud API Access Keys
WHATSAPP_ACCESS_TOKEN=your_meta_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# Shopify GraphQL Credentials
SHOPIFY_STORE_URL=your-store-handle.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_custom_app_admin_access_token
SHOPIFY_API_VERSION=2024-07

# LLM Gateway Keys
GROQ_API_KEY=gsk_your_groq_api_key
OPENROUTER_API_KEY=sk-or-your_openrouter_api_key

# Cloudflare R2 / AWS S3 Storage Credentials (Optional local static server fallback if blank)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=shopify-listing-media
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL_PREFIX=https://pub-your-id.r2.dev
